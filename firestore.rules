rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function householdData(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId)).data;
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && householdId != null
        && householdId != ""
        && exists(/databases/$(database)/documents/households/$(householdId))
        && (
          householdData(householdId).get("ownerId", "") == request.auth.uid
          || request.auth.uid in householdData(householdId).get("memberIds", [])
        );
    }

    function effectiveOwner(data) {
      return data.get("ownerId", data.get("userId", null));
    }

    function isHouseholdScope(data) {
      return signedIn()
        && data.get("householdId", "") != ""
        && isHouseholdMember(data.get("householdId", ""));
    }

    function canRead(data) {
      return (signedIn() && effectiveOwner(data) == request.auth.uid) || isHouseholdScope(data);
    }

    function canWrite(data) {
      return signedIn()
        && effectiveOwner(data) == request.auth.uid
        && (
          !("householdId" in data)
          || data.householdId == null
          || data.householdId == ""
          || isHouseholdMember(data.householdId)
        );
    }

    function scopeUnchanged() {
      return effectiveOwner(request.resource.data) == effectiveOwner(resource.data);
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /users/{userId}/{subCollection}/{docId} {
      allow read, write: if isSelf(userId);
    }

    match /households/{householdId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid

          || (
            !(request.auth.uid in resource.data.get("memberIds", []))
            && request.auth.uid in request.resource.data.get("memberIds", [])
            && request.resource.data.ownerId == resource.data.ownerId
          )
        );

      allow delete: if signedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /householdJoinCodes/{code} {
      allow read, write: if signedIn();
    }

    match /inventory/{itemId} {
      allow read:   if canRead(resource.data);
      allow delete: if canRead(resource.data);
      allow create: if canWrite(request.resource.data);
      allow update: if canRead(resource.data)
                    && canWrite(request.resource.data)
                    && scopeUnchanged();
    }

    match /shopping/{itemId} {
      allow read:   if canRead(resource.data);
      allow delete: if canRead(resource.data);
      allow create: if canWrite(request.resource.data);
      allow update: if canRead(resource.data)
                    && canWrite(request.resource.data)
                    && scopeUnchanged();
    }

    match /impact/{itemId} {
      allow read:   if canRead(resource.data);
      allow delete: if canRead(resource.data);
      allow create: if canWrite(request.resource.data);
      allow update: if canRead(resource.data)
                    && canWrite(request.resource.data)
                    && scopeUnchanged();
    }

    match /priceHistory/{entryId} {
      allow read:   if canRead(resource.data);
      allow delete: if canRead(resource.data);
      allow create: if canWrite(request.resource.data);
      allow update: if canRead(resource.data)
                    && canWrite(request.resource.data)
                    && scopeUnchanged();
    }

    match /householdEvents/{eventId} {
      allow read:   if canRead(resource.data);
      allow delete: if canRead(resource.data);
      allow create: if canWrite(request.resource.data)
                    && "householdId" in request.resource.data
                    && request.resource.data.householdId != null
                    && request.resource.data.householdId != "";
      allow update: if canRead(resource.data)
                    && canWrite(request.resource.data)
                    && scopeUnchanged();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
