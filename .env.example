# Firebase — create a project at https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
# Web Push (FCM) VAPID public key — Firebase console > Project settings >
# Cloud Messaging > Web Push certificates. Public/client-safe.
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key

# Groq — LLM inference for AI recipe suggestions https://console.groq.com
# SECRET: no VITE_ prefix, so it is never bundled into the client. The Vite dev
# proxy (vite.config.js) and the Vercel serverless function (api/groq.js) both
# read GROQ_API_KEY server-side and inject the Authorization header for the
# client. On Vercel, set GROQ_API_KEY in the project's Environment Variables.
GROQ_API_KEY=your_groq_api_key
# Non-secret: the model name is safe to expose to the client bundle.
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Unsplash — food photography https://unsplash.com/developers
VITE_UNSPLASH_KEY=your_unsplash_access_key

# App tuning
VITE_RECIPE_BATCH_SIZE=6
